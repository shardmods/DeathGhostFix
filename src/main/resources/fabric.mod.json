    "main": ["sh.lyosha.deathghostfix.DeathGhostFixMod"]
  },
  "mixins": [
    "deathghostfix.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18",
    "minecraft": "1.21.11",
    "fabric-lifecycle-events-v1": "*"
  }
}
